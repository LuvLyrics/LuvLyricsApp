# Copy this file to .env for local development.
# Do not commit real keys, tokens, or credentials.

# Google sign-in / auth
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Lyrics/search providers
EXPO_PUBLIC_GENIUS_ACCESS_TOKEN=
EXPO_PUBLIC_SAAVN_API_URL=
EXPO_PUBLIC_SAAVN_SECONDARY_API_URL=
EXPO_PUBLIC_GAANA_API_URL=
EXPO_PUBLIC_API_SECRET=

# Spotify metadata flows
# These are public in the mobile app bundle. Do not ship a real client secret
# in production mobile builds; use a backend/proxy for secret-based auth.
EXPO_PUBLIC_SPOTIFY_CLIENT_ID=
EXPO_PUBLIC_SPOTIFY_CLIENT_SECRET=
